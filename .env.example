# CodeCarbonOps Environment Configuration

# ElectricityMaps API Key (for real-time carbon data)
# Get free key at: https://api-portal.electricitymaps.com/
# Free tier: 100 requests/month
ELECTRICITY_MAPS_API_KEY=your_api_key_here

# Database URL (optional, defaults to SQLite)
# For PostgreSQL: postgresql://user:password@localhost:5432/codecarbonops
# DATABASE_URL=sqlite:///codecarbonops.db
